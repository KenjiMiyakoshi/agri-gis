{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "AgriGis": "Host=localhost;Port=5432;Database=agri_gis;Username=agri_user;Password=agri_pass"
  },
  "Jwt": {
    "Issuer": "agri-gis-api",
    "Audience": "agri-gis-windows",
    "ExpiryHours": 8
  },
  "BulkInsert": {
    "MaxCountPerChunk": 5000,
    "ChunkDefaultSize": 1000
  },
  "GeoServer": {
    "BaseUrl": "http://geoserver:8080/geoserver",
    "AdminUser": "admin",
    "AdminPasswordEnv": "AGRI_GIS_GEOSERVER_ADMIN_PASSWORD",
    "Workspace": "agrigis"
  }
}
